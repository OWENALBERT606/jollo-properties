generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  LAND_OFFICER
  PUBLIC_USER
}

enum PropertyTenure {
  MAILO
  KIBANJA
  TITLED
  LEASEHOLD
  FREEHOLD
}

enum PropertyStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  TRANSFERRED
  DISPUTED
  ARCHIVED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
  INDUSTRIAL
  LAND
  HOUSE
  OTHER
  MIXED_USE
}

enum TransactionType {
  SALE
  LEASE
  TRANSFER
  MORTGAGE
}

enum TransactionStatus {
  INITIATED
  UNDER_REVIEW
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
}

enum DisputeStatus {
  FILED
  UNDER_INVESTIGATION
  HEARING
  RESOLVED
  DISMISSED
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum DocumentType {
  TITLE_DEED
  SURVEY_MAP
  AGREEMENT
  PHOTO
  OTHER
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  nin          String?  @unique
  ninVerified  Boolean  @default(false)
  role         UserRole @default(PUBLIC_USER)
  image        String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  ownerships     PropertyOwner[]
  initiatedTx    Transaction[]   @relation("InitiatedTransactions")
  buyerTx        Transaction[]   @relation("BuyerTransactions")
  sellerTx       Transaction[]   @relation("SellerTransactions")
  valuations     Valuation[]
  disputes       Dispute[]
  auditLogs      AuditLog[]
  workflowSteps  WorkflowStep[]
  accounts       Account[]
  sessions       Session[]
  disputeNotes   DisputeNote[]
  documents      Document[]
}

// ─── Property ─────────────────────────────────────────────────────────────────

model Property {
  id              String         @id @default(cuid())
  plotNumber      String         @unique
  title           String
  description     String?        @db.Text
  district        String
  county          String?
  subcounty       String?
  village         String?
  address         String?
  size            Decimal        @db.Decimal(10, 4)
  sizeUnit        String         @default("acres")
  tenure          PropertyTenure
  type            PropertyType
  status          PropertyStatus @default(DRAFT)
  condition       String?
  price           Decimal?       @db.Decimal(15, 2)
  latitude        Float?
  longitude       Float?
  boundary        Json?
  isFeatured      Boolean        @default(false)
  isPublicListing Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  owners        PropertyOwner[]
  documents     Document[]
  transactions  Transaction[]
  valuations    Valuation[]
  disputes      Dispute[]
  workflowSteps WorkflowStep[]
  auditLogs     AuditLog[]
}

// ─── PropertyOwner ────────────────────────────────────────────────────────────

model PropertyOwner {
  id              String   @id @default(cuid())
  propertyId      String
  userId          String
  sharePercentage Decimal  @default(100) @db.Decimal(5, 2)
  isPrimary       Boolean  @default(false)
  startDate       DateTime @default(now())
  endDate         DateTime?
  isActive        Boolean  @default(true)
  notes           String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId, isActive])
}

// ─── Document ─────────────────────────────────────────────────────────────────

model Document {
  id           String       @id @default(cuid())
  propertyId   String
  uploadedById String
  name         String
  type         DocumentType @default(OTHER)
  r2Key        String
  r2Url        String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime     @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])
}

// ─── Transaction ──────────────────────────────────────────────────────────────

model Transaction {
  id            String            @id @default(cuid())
  propertyId    String
  type          TransactionType
  status        TransactionStatus @default(INITIATED)
  initiatedById String
  buyerId       String?
  sellerId      String?
  amount        Decimal?          @db.Decimal(15, 2)
  currency      String            @default("UGX")
  agreementDate DateTime?
  completedDate DateTime?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  property    Property       @relation(fields: [propertyId], references: [id])
  initiatedBy User           @relation("InitiatedTransactions", fields: [initiatedById], references: [id])
  buyer       User?          @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller      User?          @relation("SellerTransactions", fields: [sellerId], references: [id])
  workflowSteps WorkflowStep[]
  auditLogs   AuditLog[]
}

// ─── Valuation ────────────────────────────────────────────────────────────────

model Valuation {
  id            String   @id @default(cuid())
  propertyId    String
  officerId     String
  valuedAmount  Decimal  @db.Decimal(15, 2)
  taxAmount     Decimal  @db.Decimal(15, 2)
  taxRate       Decimal  @db.Decimal(5, 4)
  valuationDate DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  property Property     @relation(fields: [propertyId], references: [id])
  officer  User         @relation(fields: [officerId], references: [id])
  payments TaxPayment[]
}

// ─── TaxPayment ───────────────────────────────────────────────────────────────

model TaxPayment {
  id            String   @id @default(cuid())
  valuationId   String
  amount        Decimal  @db.Decimal(15, 2)
  receiptNumber String   @unique @default(cuid())
  paidAt        DateTime @default(now())
  method        String   @default("CASH")
  notes         String?

  valuation Valuation @relation(fields: [valuationId], references: [id])
}

// ─── Dispute ──────────────────────────────────────────────────────────────────

model Dispute {
  id           String        @id @default(cuid())
  propertyId   String
  complainantId String
  title        String
  description  String        @db.Text
  status       DisputeStatus @default(FILED)
  resolution   String?       @db.Text
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property    Property      @relation(fields: [propertyId], references: [id])
  complainant User          @relation(fields: [complainantId], references: [id])
  notes       DisputeNote[]
}

// ─── DisputeNote ──────────────────────────────────────────────────────────────

model DisputeNote {
  id        String   @id @default(cuid())
  disputeId String
  note      String   @db.Text
  addedById String
  createdAt DateTime @default(now())

  dispute  Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  addedBy  User    @relation(fields: [addedById], references: [id])
}

// ─── WorkflowStep ─────────────────────────────────────────────────────────────

model WorkflowStep {
  id            String         @id @default(cuid())
  propertyId    String?
  transactionId String?
  stepName      String
  assigneeId    String?
  status        WorkflowStatus @default(PENDING)
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())

  property    Property?    @relation(fields: [propertyId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  assignee    User?        @relation(fields: [assigneeId], references: [id])
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  action        String
  entityType    String
  entityId      String
  propertyId    String?
  transactionId String?
  oldValue      Json?
  newValue      Json?
  ip            String?
  createdAt     DateTime @default(now())

  actor       User?        @relation(fields: [actorId], references: [id])
  property    Property?    @relation(fields: [propertyId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
}

// ─── Lookup / Reference Models ───────────────────────────────────────────────

model PropertyCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TenureType {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model District {
  id        String   @id @default(cuid())
  name      String   @unique
  region    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MainRoad {
  id        String   @id @default(cuid())
  name      String   @unique
  district  String
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model County {
  id        String   @id @default(cuid())
  name      String
  district  String
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, district])
}

model Subcounty {
  id        String   @id @default(cuid())
  name      String
  county    String
  district  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, county, district])
}

model Street {
  id         String   @id @default(cuid())
  name       String
  subcounty  String?
  district   String
  region     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, district])
}
